{
  "name": "ethtrainer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "setup-wallet": "tsx scripts/setup-wallet.ts",
    "seed-params": "tsx scripts/seed-params.ts",
    "autoresearch": "tsx scripts/run-autoresearch.ts",
    "compile": "hardhat compile",
    "deploy:liquidation": "tsx scripts/deploy-liquidation-bot.ts",
    "deploy:base": "tsx scripts/deploy-liquidation-bot-base.ts",
    "build:rust": "cargo build --release -p liquidator"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "telegraf": "^4.16.3",
    "viem": "^2.21.54",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^22.10.2",
    "hardhat": "^2.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
