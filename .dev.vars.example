# Copy this to .dev.vars and fill in your values.
# NEVER commit .dev.vars to git.

# ── AI ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Ethereum ──────────────────────────────────────────
ETH_RPC_URL=http://localhost:8545
ETH_RPC_URL_WS=ws://localhost:8546
NETWORK=holesky

# ── Wallet ────────────────────────────────────────────
# Path to encrypted JSON keystore file (outside repo)
KEYSTORE_PATH=/Users/YOUR_USERNAME/.ethtrainer/keystore.json
# Password stored in macOS Keychain — set it once with:
# security add-generic-password -s ETHTrainer -a trading_wallet -w "your_password"
KEYCHAIN_SERVICE=ETHTrainer
KEYCHAIN_ACCOUNT=trading_wallet

# ── Treasury ──────────────────────────────────────────
# Cold wallet address — agent can ONLY send TO this, never spend from it
TREASURY_ADDRESS=0x

# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Arbitrum (liquidation bot) ────────────────────────
# Separate RPC for Arbitrum — Alchemy, Infura, or own node
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL_WS=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Base (liquidation bot) ────────────────────────
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL_WS=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Deployed Contracts ────────────────────────────────
# Set after running: npm run deploy:liquidation and npm run deploy:base
LIQUIDATION_BOT_ADDRESS=
LIQUIDATION_BOT_ADDRESS_BASE=

# ── Agent Config ──────────────────────────────────────
OBSIDIAN_VAULT_PATH=/Users/treeseedtreeseed/Documents/Obsidian Vault/Charlie Munger's Mental Models
TRADING_WALLET_FLOOR_ETH=0.5
TREASURY_SWEEP_PCT=25
TREASURY_SWEEP_MIN_ETH=0.05
